{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flutter Debug Adapter Configuration",
  "type": "object",
  "properties": {
    "adapter": {
      "type": "string",
      "enum": [
        "Flutter"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "flutter"
      ],
      "description": "Debug Flutter application",
      "default": "flutter"
    },
    "label": {
      "type": "string",
      "description": "Human-readable name for this debug configuration",
      "examples": [
        "Launch Flutter App",
        "Debug Flutter",
        "Flutter Development"
      ]
    },
    "program": {
      "type": "string",
      "description": "Path to the Flutter app entry point",
      "default": "lib/main.dart",
      "examples": [
        "lib/main.dart",
        "lib/app.dart"
      ]
    },
    "cwd": {
      "type": "string",
      "description": "Path to the working directory"
    },
    "useFvm": {
      "type": "boolean",
      "description": "Use FVM (Flutter Version Manager) to run the Flutter program"
    },
    "args": {
      "type": "array",
      "description": "Arguments passed to the Flutter program",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "device_id": {
      "type": "string",
      "description": "Target device ID (auto-selected if not specified)",
      "examples": [
        "chrome",
        "edge",
        "macos",
        "windows",
        "linux",
        "<android-device-id>",
        "<ios-device-id>"
      ]
    },
    "platform": {
      "type": "string",
      "description": "Target platform (auto-detected from device if not specified)",
      "enum": [
        "web",
        "ios",
        "android",
        "macos",
        "windows",
        "linux"
      ]
    },
    "request": {
      "type": "string",
      "enum": [
        "launch",
        "attach"
      ],
      "description": "The debug request type",
      "default": "launch"
    },
    "vmServiceUri": {
      "type": "string",
      "description": "The VM Service URI to attach to (for attach mode)"
    },
    "flutterMode": {
      "type": "string",
      "enum": [
        "debug",
        "profile",
        "release"
      ],
      "description": "Flutter build mode",
      "default": "debug"
    },
    "flutterPlatform": {
      "type": "string",
      "description": "Target platform variant",
      "examples": [
        "android-arm",
        "android-arm64",
        "android-x86",
        "ios",
        "web"
      ]
    },
    "stopOnEntry": {
      "type": "boolean",
      "description": "Pause debugger on entry",
      "default": false
    },
    "supportsHotReload": {
      "type": "boolean",
      "description": "Enable hot reload support",
      "default": true
    },
    "hotReloadOnSave": {
      "type": "boolean",
      "description": "Automatically trigger hot reload on file save",
      "default": true
    },
    "hotRestartOnSave": {
      "type": "boolean",
      "description": "Automatically trigger hot restart on force-save (Cmd+Shift+S)",
      "default": false
    },
    "showMemoryUsage": {
      "type": "boolean",
      "description": "Show memory usage information",
      "default": false
    },
    "enableVmService": {
      "type": "boolean",
      "description": "Enable VM service for debugging",
      "default": true
    },
    "vmServicePort": {
      "type": "number",
      "description": "Port for VM service (0 for auto-assign)",
      "default": 0
    },
    "flutterTest": {
      "type": "boolean",
      "description": "Run in Flutter test mode",
      "default": false
    },
    "additionalArgs": {
      "type": "array",
      "description": "Additional arguments to pass to flutter run",
      "items": {
        "type": "string"
      },
      "examples": [
        "--flavor",
        "development",
        "--dart-define",
        "ENV=dev"
      ]
    }
  },
  "required": [
    "program",
    "type",
    "adapter"
  ],
  "additionalProperties": false
}
